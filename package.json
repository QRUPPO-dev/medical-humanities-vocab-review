{
  "name": "medical-humanities-vocab-review",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "ios:sync": "vite build && cap sync ios",
    "ios:open": "cap open ios",
    "android:sync": "vite build && cap sync android",
    "android:open": "cap open android",
    "android:debug-apk": "vite build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:release-apk": "vite build && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  }
}
